import time
import json
import os
import yaylib

bot = yaylib.Client()
bot.login("メール", "パスワード")

LIKE_LIMIT = 20
FOLLOW_LIMIT = 10
ROOM_SLEEP = 4
SLEEP_BETWEEN = 3
CYCLE_SLEEP = 60

LIKE_FILE = "liked_posts.json"
FOLLOW_FILE = "followed_users.json"


def load_data(file):
    if os.path.exists(file):
        with open(file, "r", encoding="utf-8") as f:
            return set(json.load(f))
    return set()


def save_data(file, data):
    with open(file, "w", encoding="utf-8") as f:
        json.dump(list(data), f, ensure_ascii=False, indent=2)


liked_posts = load_data(LIKE_FILE)
followed_users = load_data(FOLLOW_FILE)

print("BOT起動（枠フォロー統合版）")

while True:
    try:
        like_count = 0
        follow_count = 0

        # =========================
        # タイムライン処理
        # =========================
        timeline = bot.get_timeline()
        posts = getattr(timeline, "posts", None) or getattr(timeline, "data", []) or []

        for post in posts:
            post_id = getattr(post, "id", None)
            user = getattr(post, "user", None)
            user_id = getattr(user, "id", None) if user else None

            # いいね
            if post_id and post_id not in liked_posts and like_count < LIKE_LIMIT:
                try:
                    bot.like(post_id)
                    liked_posts.add(post_id)
                    like_count += 1
                    print("👍 いいね:", post_id)
                    time.sleep(SLEEP_BETWEEN)
                except Exception as e:
                    print("いいねエラー:", e)

            # 投稿者フォロー
            if user_id and user_id not in followed_users and follow_count < FOLLOW_LIMIT:
                try:
                    bot.follow_user(user_id)
                    followed_users.add(user_id)
                    follow_count += 1
                    print("➕ 投稿者フォロー:", user_id)
                    time.sleep(SLEEP_BETWEEN)
                except Exception as e:
                    print("フォローエラー:", e)

        # =========================
        # 枠フォロー処理
        # =========================
        try:
            rooms = bot.get_rooms()

            for room in rooms:
                room_id = getattr(room, "id", None)

                try:
                    users = bot.get_room_users(room_id)

                    for user in users:
                        user_id = getattr(user, "id", None)

                        if user_id and user_id not in followed_users:
                            try:
                                bot.follow_user(user_id)
                                followed_users.add(user_id)

                                print("🎧 枠フォロー:", user_id)
                                time.sleep(ROOM_SLEEP)

                            except Exception as e:
                                print("枠フォローエラー:", e)

                except Exception:
                    continue

        except Exception as e:
            print("枠取得エラー:", e)

        save_data(LIKE_FILE, liked_posts)
        save_data(FOLLOW_FILE, followed_users)

        print("1周完了")
        time.sleep(CYCLE_SLEEP)

    except Exception as e:
        print("メインエラー:", e)
        time.sleep(10)
